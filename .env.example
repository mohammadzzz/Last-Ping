# --- Core ---
NODE_ENV=development
APP_URL=https://last-ping.example.com
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://lastping:lastping@db:5432/lastping?schema=public

# --- Storage ---
DATA_DIR=/data

# --- Crypto ---
# 32 random bytes, base64-encoded. Generate: `openssl rand -base64 32`
MASTER_KEK=
# Pepper for password/PIN hashing. Generate: `openssl rand -base64 32`
AUTH_PEPPER=
# Iron-session secret, min 32 chars. Generate: `openssl rand -base64 48`
SESSION_SECRET=
# Salt for hashing client IPs in logs.
IP_HASH_SALT=

# --- Inactivity windows (seconds) ---
WARNING_AFTER_SECONDS=604800       # 7 days
RELEASE_AFTER_SECONDS=1209600      # 14 days
RECIPIENT_EXPIRY_SECONDS=2592000   # 30 days
POST_DOWNLOAD_RETENTION_SECONDS=259200  # 3 days

# --- Test mode clock acceleration ---
# When AppState.testMode = true, multiply wall-clock deltas used for state
# transitions by this factor (e.g. 3600 = 1 real second -> 1 test hour).
TEST_MODE_SPEEDUP=3600

# --- Notifications: Resend ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# --- Notifications: Telegram ---
TELEGRAM_BOT_TOKEN=
# Owner's own chat ID (for warnings).
TELEGRAM_OWNER_CHAT_ID=

# --- Notifications: Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886

# --- Owner warning channels (comma-separated: EMAIL,TELEGRAM,SMS,WHATSAPP) ---
OWNER_WARNING_CHANNELS=EMAIL,TELEGRAM
OWNER_CONTACT_EMAIL=
OWNER_CONTACT_PHONE=
OWNER_CONTACT_WHATSAPP=
